# Copy this file to .env and fill in your real EmailJS keys.
# .env is gitignored and will NOT be committed or pushed to GitHub.
# On Vercel, add these same 4 variables under:
#   Project Settings -> Environment Variables

VITE_EMAILJS_PUBLIC_KEY=your_public_key_here
VITE_EMAILJS_SERVICE_ID=your_service_id_here
VITE_EMAILJS_CONTACT_TEMPLATE_ID=your_contact_template_id_here
VITE_EMAILJS_APPOINTMENT_TEMPLATE_ID=your_appointment_template_id_here
